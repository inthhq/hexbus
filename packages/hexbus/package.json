{
	"name": "hexbus",
	"version": "0.1.0",
	"description": "Opinionated CLI chassis for Hexbus command-line tools.",
	"homepage": "https://github.com/inthhq/hexbus/tree/main/packages/hexbus",
	"repository": {
		"type": "git",
		"url": "https://github.com/inthhq/hexbus.git",
		"directory": "packages/hexbus"
	},
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun --bun tsdown",
		"check-types": "tsc --noEmit",
		"dev": "tsdown --watch",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@clack/prompts": "1.1.0",
		"c12": "3.3.3",
		"figlet": "1.11.0",
		"picocolors": "1.1.1"
	},
	"devDependencies": {
		"@inth/typescript-config": "workspace:*",
		"@inth/vitest-config": "workspace:*",
		"@types/figlet": "1.7.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
