{
  "name": "hexbus",
  "version": "0.1.1",
  "description": "Opinionated CLI framework for Inth apps.",
  "homepage": "https://github.com/inthhq/hexbus/tree/main/packages/hexbus",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/inthhq/hexbus.git",
    "directory": "packages/hexbus"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun --bun tsdown",
    "check-types": "tsc --noEmit",
    "dev": "tsdown --watch",
    "fmt": "oxfmt --write .",
    "lint": "oxlint ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "c12": "3.3.3",
    "figlet": "1.11.0"
  },
  "devDependencies": {
    "@inth/typescript-config": "workspace:*",
    "@inth/vitest-config": "workspace:*",
    "@types/figlet": "1.7.0"
  }
}
