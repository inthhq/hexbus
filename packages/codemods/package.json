{
  "name": "@inth/hexbus-codemods",
  "version": "0.5.0",
  "description": "Reusable codemod harness for Hexbus CLIs.",
  "homepage": "https://github.com/inthhq/hexbus/tree/main/packages/codemods",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inthhq/hexbus.git",
    "directory": "packages/codemods"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun --bun tsdown",
    "check-types": "tsc --noEmit",
    "dev": "tsdown --watch",
    "fmt": "oxfmt --write .",
    "lint": "oxlint ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hexbus": "workspace:*",
    "ts-morph": "27.0.2"
  },
  "devDependencies": {
    "@inth/typescript-config": "workspace:*",
    "@inth/vitest-config": "workspace:*"
  }
}
