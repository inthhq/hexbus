{
  "extends": "@inth/typescript-config/node.json",
  "compilerOptions": {
    "rootDir": "src",
    "lib": ["esnext"],
    "paths": {
      "~/*": ["./src/*"]
    },
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
